pkgname="qnx-sensor-framework"
pkgver=8.0.4
_sensor_version=0.3.0.00207T202507171524L
pkgrel=0
pkgdesc="QNX Sensor Framework"
url="https://qnx.com"
arch="all"
license="LicenseRef-QDL-Non-Commercial"
options="!strip !tracedeps"
subpackages="$pkgname-dev $pkgname-dbg"
depends="qnx-libslog2 qnx-zlib"
source="sensor_$_sensor_version.qpkg::$QSC_URL/com.qnx.qnx800.target.sf.sensor/$_sensor_version/download
"

prepare() {
   cd "$srcdir"
   for qpkg in *.qpkg; do
        tar xf $qpkg
   done
}

# extglob for trimming out other arch's toolchain
shopt -s extglob
package() {
    mkdir -p "$pkgdir"/usr

    if [[ $CARCH == "aarch64" ]]; then
        _arch_name=aarch64le
    elif [[ $CARCH == "x86_64" ]]; then
        _arch_name=x86_64
    fi

    cp -r "$srcdir"/target/qnx/$_arch_name/usr/bin "$pkgdir"/usr
    cp -r "$srcdir"/target/qnx/$_arch_name/usr/lib "$pkgdir"/usr

    echo "Moving common usr"
    cp -r "$srcdir"/target/qnx/usr/ "$pkgdir"
}

dbg() {
    amove "usr/bin/*.sym"
    amove "usr/lib/*.sym"
}

sha512sums="
80c01a6198fa9d46dd582cd77c7bbc71c71aafe952224c43827fa326d492fa04d20d02cb89f2c51f001ab662178d4bad22997dcef2bd889a5401fe356f7d6b4d  sensor_0.3.0.00207T202507171524L.qpkg
"
