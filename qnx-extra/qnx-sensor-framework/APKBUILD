pkgname="qnx-sensor-framework"
pkgver=8.0.3
_sensor_version=0.3.0.00207T202507171524L
_sensor_util_version=0.2.0.00128T202503270827L
pkgrel=0
pkgdesc="QNX Sensor Framework"
url="https://qnx.com"
arch="all"
license="LicenseRef-QDL-Non-Commercial"
options="!strip !tracedeps"
# make sure that util is run before dev
subpackages="$pkgname-util $pkgname-dev $pkgname-dbg"
depends="qnx-libslog2 qnx-zlib"
source="
sensor_$_sensor_version.qpkg::$QSC_URL/com.qnx.qnx800.target.sf.sensor/$_sensor_version/download
sensor_util_$_sensor_util_version.qpkg::$QSC_URL/com.qnx.qnx800.target.sf.base/$_sensor_util_version/download
"

prepare() {
   cd "$srcdir"
   for qpkg in *.qpkg; do
        tar xf $qpkg
   done
}

# extglob for trimming out other arch's toolchain
shopt -s extglob
package() {
    mkdir -p "$pkgdir"/usr

    if [[ $CARCH == "aarch64" ]]; then
        _arch_name=aarch64le
    elif [[ $CARCH == "x86_64" ]]; then
        _arch_name=x86_64
    fi

    cp -r "$srcdir"/target/qnx/$_arch_name/usr/bin "$pkgdir"/usr
    cp -r "$srcdir"/target/qnx/$_arch_name/usr/lib "$pkgdir"/usr

    echo "Moving common usr"
    cp -r "$srcdir"/target/qnx/usr/ "$pkgdir"
}

dbg() {
    amove "usr/bin/*.sym"
    amove "usr/lib/*.sym"
}

util() {
    pkgdesc="Utility headers for QNX Sensor framework"
    amove "usr/include/sensor_utils"
}

