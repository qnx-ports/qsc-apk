+static char* parse_irq(char *irq_str, uint_t *irq, uint32_t *cfg) {
+    /**
+     * irq_str is a number followed by an optional configuration string
+     * <number>[cfg]
+     * where cfg is a combination of the letters
+     * e == (e)dge triggered
+     * l == (l)evel triggered
+     */
+    char *ch;
+    uint_t num;
+    int c = 0;
