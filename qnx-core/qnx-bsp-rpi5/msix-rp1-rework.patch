+    /* Parse the number */
+    num = strtoul(irq_str, &ch, 10);
+    if (num >= RP1_PCIE_MSIX_IRQ_SIZE) {
+        (void)fprintf(stderr, "IRQ %u out of range. Must be between 0 and %u\n", num, RP1_PCIE_MSIX_IRQ_SIZE);
+        return NULL;
+    } else if ((num == 0 && ch == irq_str) || irq_str[0] == '\0') {
+        (void)fprintf(stderr, "IRQ is invalid\n");
+        return NULL;
+    }
+
+    /* Parse the cfg string */
+    if (*ch == 'D') {
+        c |= IRQ_CFG_DISABLE_IRQ;
+        ch++;
+    }
+    /* RP1 Config */
+    if (*ch == 'e') {
+        c |= IRQ_CFG_RP1_TRIGGER_EDGE;
+        ch++;
+    } else if (*ch == 'l') {
+        ch++;
+    } else if (*ch == '-' || *ch == ',' || *ch == '\0') {
