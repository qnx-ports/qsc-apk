# Maintainer: Aaron Bassett <abassett@qnx.com>
pkgname="qnx-os-services"
pkgver=8.0.4
_os_service_version=1.0.0.03063T202511271306L
_os_service_mqueue_version=1.1.0.00111T202602271127L
_os_service_libjson_version=0.4.0.03063T202511271306L
pkgrel=0
pkgdesc="QNX Meta Package for Operating System Services Base"
url="https://qnx.com"
arch="all"
license="LicenseRef-QDL-Non-Commercial"
options="!strip noarch !tracedeps"
depends="$pkgname-pipe=$pkgver-r$pkgrel $pkgname-mqueue=$pkgver-r$pkgrel"
depends_dev="$pkgname-pipe-dev $pkgname-mqueue-dev"
subpackages="$pkgname-dev 
    $pkgname-pipe:pipe $pkgname-pipe-dbg:pipe-dbg
    $pkgname-mqueue:mqueue $pkgname-mqueue-dbg:mqueue-dbg
    qnx-libjson:libjson qnx-libjson-dev:libjson-dev qnx-libjson-dbg:libjson-dbg
"
source="os-services-base_$_os_service_version.qpkg::$QSC_URL/com.qnx.qnx800.target.os_services.base/$_os_service_version/download
os-services-mqueue_$_os_service_mqueue_version.qpkg::$QSC_URL/com.qnx.qnx800.target.os_services.mqueue/$_os_service_mqueue_version/download
os-services-libjson_$_os_service_libjson_version.qpkg::$QSC_URL/com.qnx.qnx800.target.os_services.libjson/$_os_service_libjson_version/download
"

prepare() {
   for qpkg in *.qpkg; do
        tar xf $qpkg
   done
}

# extglob for trimming out other arch's toolchain
shopt -s extglob
package() {
    mkdir -p "$pkgdir"/usr/bin
    _qarch=$CARCH
    if [[ $CARCH == "aarch64" ]]; then
        export _qarch=aarch64le
    fi
    mkdir -p $pkgdir/usr/{bin,lib}
    echo "Moving libjson headers"
    cp -r "$srcdir"/target/qnx/usr/include "$pkgdir"/usr/
    echo "Moving arch-specific ($_qarch) libjson libraries"
    cp -r "$srcdir"/target/qnx/$_qarch/lib/* "$pkgdir"/usr/lib/
    echo "Moving arch-specific ($_qarch) binaries"
    cp -r "$srcdir"/target/qnx/$_qarch/sbin/{pipe*,mqueue*} "$pkgdir"/usr/bin/
}

dev() {
    mkdir "$subpkgdir"
}

pipe() {
    depends="qnx-secpol"
    amove usr/bin/pipe 
}

pipe-dbg() {
    depends="$pkgname-pipe=$pkgver-r$pkgrel"
    amove usr/bin/pipe.sym
}

mqueue() {
    depends="qnx-secpol"
    amove usr/bin/mqueue
}

mqueue-dbg() {
     depends="$pkgname-pipe=$pkgver-r$pkgrel"
     amove usr/bin/mqueue.sym
}

libjson() {
    amove usr/lib/libjson.so.1
}

libjson-dev() {
    amove usr/include
    amove usr/lib/libjson.so
}

libjson-dbg() {
    amove usr/lib/libjson.so.1.sym
}

